# Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an

# Server
PORT=3000

# Datenbank
DB_HOST=localhost
DB_PORT=5432
DB_USER=youruser
DB_PASS=yourpassword
DB_NAME=yourdbname

# Sonstiges
NODE_ENV=development

# Füge hier weitere Variablen hinzu, die dein Projekt benötigt

